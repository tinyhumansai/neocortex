{
    "name": "@alphahuman/openclaw-model-provider",
    "version": "0.1.0",
    "description": "OpenClaw plugin that registers Alphahuman model provider",
    "type": "module",
    "keywords": [
        "openclaw",
        "plugin",
        "model-provider",
        "alphahuman"
    ],
    "license": "UNLICENSED",
    "files": [
        "src/index.ts",
        "src/openclaw.plugin.json",
        "README.md"
    ],
    "scripts": {
        "openclaw:install": "openclaw plugins install -l .",
        "openclaw:enable": "openclaw plugins enable openclaw-model-provider",
        "openclaw:setup": "openclaw plugins install -l . && openclaw plugins enable openclaw-model-provider",
        "openclaw:auth": "openclaw models auth login --provider alphahuman",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write 'src/**/*.{ts,json}'",
        "format:check": "prettier --check 'src/**/*.{ts,json}'",
        "prepare": "husky"
    },
    "peerDependencies": {
        "openclaw": ">=2026.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.29.1",
        "@typescript-eslint/parser": "^8.29.1",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.31.0",
        "husky": "^9.1.7",
        "openclaw": "^2026.2.23",
        "prettier": "^3.5.3",
        "typescript": "^5.7.0"
    },
    "openclaw": {
        "extensions": [
            "./src/index.ts"
        ]
    }
}