{
    "id": "openclaw-model-provider",
    "providers": [
        "alphahuman"
    ],
    "configSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "baseUrl": {
                "type": "string"
            },
            "apiKeyEnvVar": {
                "type": "string"
            },
            "apiKey": {
                "type": "string"
            },
            "authHeader": {
                "type": "boolean"
            },
            "modelId": {
                "type": "string"
            },
            "modelName": {
                "type": "string"
            },
            "contextWindow": {
                "type": "integer",
                "minimum": 1
            },
            "maxTokens": {
                "type": "integer",
                "minimum": 1
            },
            "supportsReasoning": {
                "type": "boolean"
            },
            "supportsImageInput": {
                "type": "boolean"
            },
            "headers": {
                "type": "object",
                "additionalProperties": {
                    "type": "string"
                }
            },
            "memorySyncEnabled": {
                "type": "boolean"
            },
            "memorySyncUrl": {
                "type": "string"
            },
            "memorySyncApiKeyEnvVar": {
                "type": "string"
            },
            "memorySyncApiKey": {
                "type": "string"
            },
            "memorySyncTimeoutMs": {
                "type": "integer",
                "minimum": 1000
            },
            "memorySyncAuthHeader": {
                "type": "boolean"
            },
            "memorySyncHeaders": {
                "type": "object",
                "additionalProperties": {
                    "type": "string"
                }
            },
            "workspaceId": {
                "type": "string"
            }
        }
    },
    "uiHints": {
        "baseUrl": {
            "label": "API Base URL",
            "placeholder": "https://your-api/openai/v1"
        },
        "apiKeyEnvVar": {
            "label": "API Key Environment Variable",
            "placeholder": "ALPHAHUMAN_API_KEY"
        },
        "apiKey": {
            "label": "Inline API Key",
            "sensitive": true,
            "advanced": true
        },
        "modelId": {
            "label": "Model ID",
            "placeholder": "neocortex-mk1"
        },
        "modelName": {
            "label": "Model Display Name",
            "placeholder": "Neocortex MK1"
        },
        "contextWindow": {
            "label": "Context Window",
            "advanced": true
        },
        "maxTokens": {
            "label": "Max Tokens",
            "advanced": true
        },
        "supportsReasoning": {
            "label": "Supports Reasoning",
            "advanced": true
        },
        "supportsImageInput": {
            "label": "Supports Image Input",
            "advanced": true
        },
        "headers": {
            "label": "Model Request Headers",
            "advanced": true
        },
        "memorySyncEnabled": {
            "label": "Enable Memory Sync"
        },
        "memorySyncUrl": {
            "label": "Memory Sync URL",
            "placeholder": "https://your-api/memory/sync"
        },
        "memorySyncApiKeyEnvVar": {
            "label": "Memory Sync API Key Env Var",
            "advanced": true
        },
        "memorySyncApiKey": {
            "label": "Inline Memory Sync API Key",
            "sensitive": true,
            "advanced": true
        },
        "memorySyncTimeoutMs": {
            "label": "Memory Sync Timeout (ms)",
            "advanced": true
        },
        "memorySyncAuthHeader": {
            "label": "Use Bearer Auth for Memory Sync",
            "advanced": true
        },
        "memorySyncHeaders": {
            "label": "Memory Sync Headers",
            "advanced": true
        },
        "workspaceId": {
            "label": "Workspace ID Override",
            "advanced": true
        }
    }
}